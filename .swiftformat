# https://github.com/nicklockwood/SwiftFormat

# file header format
--header "\n {file}\n numberConverter\n\n Created by Andreas Maier.\n Copyright © {year} Andreas Maier. All rights reserved.\n"

# options
--swiftversion 6
--indent 4
--decimalgrouping 3,3
--hexgrouping 4,8

# rules
--maxwidth 120

--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--wrapconditions before-first

--closingparen balanced

--funcattributes prev-line
--typeattributes prev-line
--varattributes same-line

--stripunusedargs unnamed-only

--wrapternary before-operators

# disabled
--disable trailingCommas

# excluded folders (ConversionEngine is a separate spm package with its own manifest;
# the app header template must not touch its Package.swift swift-tools-version line)
--exclude Pods,Carthage,.build,DerivedData,ConversionEngine
